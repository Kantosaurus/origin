  - Architecture: arm64
    InstallerUrl: https://github.com/Kantosaurus/origin/releases/download/v{{VERSION}}/origin-aarch64-pc-windows-msvc.exe
    InstallerSha256: "{{SHA256_WIN_ARM}}"
ManifestType: installer
ManifestVersion: 1.6.0
